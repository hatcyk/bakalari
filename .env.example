# Bakaláři login credentials
# Account used by the prefetch job to log in to https://mot-spsd.bakalari.cz
BAKALARI_USERNAME='your_username_here'
BAKALARI_PASSWORD='your_password_here'

# Firebase Service Account
# Local: path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH='./firebase-service-account.json'
# Vercel/CI: the entire service account JSON as a single string (use instead of the path)
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account", ...}'

# Debug mode - enables test/debug endpoints (e.g. /api/test-ntf) and extra logging.
# Keep this 'false' in production: the test endpoints are unauthenticated and can
# send notifications and expose FCM tokens.
DEBUG=false

# Skip initial prefetch on server startup (useful for development)
# Set to 'true' to skip the automatic prefetch when server starts
# You can still trigger prefetch manually via: POST /api/prefetch/trigger
SKIP_INITIAL_PREFETCH=false

# Cron Secret (protects /api/cron/* endpoints)
# Generate a random secret: openssl rand -base64 32
# Required in production — cron endpoints are refused if it is missing there.
CRON_SECRET='your_random_secret_here'

# Optional: override prefetch concurrency (defaults to 3 on Vercel, 20 elsewhere)
# PREFETCH_CONCURRENCY=10

# Optional: lesson reminder notification window (minutes before lesson start)
# LESSON_REMINDER_MINUTES_BEFORE=5
# LESSON_REMINDER_WINDOW_START=15
# LESSON_REMINDER_WINDOW_END=1
